# === SUPABASE ===
# Ambil dari: Supabase Dashboard > Project Settings > API
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=isi-dengan-service-role-key

# === MIDTRANS ===
# Ambil dari: Midtrans Dashboard > Settings > Access Keys
# Gunakan kredensial SANDBOX dulu untuk testing sebelum event.
MIDTRANS_SERVER_KEY=isi-dengan-server-key
NEXT_PUBLIC_MIDTRANS_CLIENT_KEY=isi-dengan-client-key
MIDTRANS_IS_PRODUCTION=false
NEXT_PUBLIC_MIDTRANS_IS_PRODUCTION=false

# === ADMIN ===
# Password untuk akses halaman /admin (buat sendiri, jangan pakai contoh ini)
ADMIN_PASSWORD=gantidenganpasswordkuat
